# GOOGLE_TRANSLATION_API_KEY: Required for translation features.
VITE_GOOGLE_TRANSLATION_API_KEY=

# GOOGLE_SPEECH_API_KEY: Required for speech-to-text features.
VITE_GOOGLE_SPEECH_API_KEY=

# AVIATION_STACK_API_KEY: Required for flight tracking features.
VITE_AVIATION_STACK_API_KEY=

