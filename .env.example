# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# User Provided Keys (Mapped to VITE_ equivalents where needed)
EXPO_PUBLIC_GROQ_API_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_KEY=
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
EXPO_PUBLIC_CLOUDINARY_URL=

# GOOGLE_MAPS_API_KEY: Required for Google Maps integration.
VITE_GOOGLE_MAPS_API_KEY=

# STRIPE_PUBLISHABLE_KEY: Required for Stripe payments.
VITE_STRIPE_PUBLISHABLE_KEY=

# GROQ_API_KEY: Required for Groq AI features.
GROQ_API_KEY=

# CLOUDINARY_URL: Required for Cloudinary image uploads.
CLOUDINARY_URL=

# GOOGLE_TRANSLATION_API_KEY: Required for translation features.
VITE_GOOGLE_TRANSLATION_API_KEY=

# GOOGLE_SPEECH_API_KEY: Required for speech-to-text features.
VITE_GOOGLE_SPEECH_API_KEY=

# AVIATION_STACK_API_KEY: Required for flight tracking features.
VITE_AVIATION_STACK_API_KEY=

# FREEPIK_API_KEY: Required for animated icons.
VITE_FREEPIK_API_KEY=
